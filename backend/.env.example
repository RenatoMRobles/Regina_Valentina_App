# ============================================================
# VARIABLES DE ENTORNO — Regina Valentina Backend
# Copia este archivo como .env y llena los valores reales.
# NUNCA subas el archivo .env al repositorio.
# En Cloud Run estas variables se inyectan desde Secret Manager.
# ============================================================

# IA Generativa (Gemini 2.5 Flash)
GEMINI_API_KEY=

# Google Text-to-Speech (Voz Premium)
TTS_API_KEY=

# Anthropic Claude (reservado para futuras funciones)
ANTHROPIC_API_KEY=

# MercadoPago (token de producción o sandbox)
MERCADOPAGO_ACCESS_TOKEN=

# Flask — clave secreta para sesiones/firmado de tokens
SECRET_KEY=
